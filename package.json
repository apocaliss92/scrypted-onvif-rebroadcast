{
   "name": "@apocaliss92/scrypted-onvif-rebroadcast",
   "description": "Scrypted mixin plugin that exposes cameras as ONVIF devices using Scrypted Rebroadcast RTSP streams",
   "repository": {
      "type": "git",
      "url": "https://github.com/apocaliss92/scrypted-onvif-rebroadcast"
   },
   "version": "0.0.1",
   "scripts": {
      "scrypted-setup-project": "scrypted-setup-project",
      "prescrypted-setup-project": "scrypted-package-json",
      "build": "scrypted-webpack",
      "prepublishOnly": "NODE_ENV=production scrypted-webpack",
      "prescrypted-vscode-launch": "scrypted-webpack",
      "scrypted-vscode-launch": "scrypted-deploy-debug",
      "scrypted-deploy-debug": "scrypted-deploy-debug",
      "scrypted-debug": "scrypted-debug",
      "scrypted-deploy": "scrypted-deploy",
      "scrypted-readme": "scrypted-readme",
      "scrypted-package-json": "scrypted-package-json"
   },
   "keywords": [
      "scrypted",
      "plugin",
      "onvif",
      "rtsp",
      "rebroadcast",
      "camera",
      "mixin",
      "server"
   ],
   "scrypted": {
      "name": "ONVIF Rebroadcast",
      "type": "API",
      "interfaces": [
         "Settings",
         "MixinProvider"
      ],
      "pluginDependencies": []
   },
   "dependencies": {
      "@scrypted/sdk": "0.5.53",
      "lodash": "^4.17.21",
      "uuid": "^9.0.0",
      "xml2js": "^0.6.2"
   },
   "devDependencies": {
      "@types/lodash": "^4.17.12",
      "@types/node": "^20.11.0",
      "@types/uuid": "^9.0.7",
      "@types/xml2js": "^0.4.14"
   }
}
